# Return true if every item of "xs" satisfies the predicate "f" (a truthy
# result). Input: {"f": predicate, "xs": array}.
(
  {"f": _, "xs": []} => true,
  {"f": f, "xs": [x, ...rest]} => [x | f, {"f": f, "xs": rest} | @all] | @and,
  x => !{"kind": "argument_error", "origin": "stdlib", "operation": "@all", "status": 0, "input": x | @sanitize, "expected": ["{\"f\": _, \"xs\": _ ? @Array}"]}
)
