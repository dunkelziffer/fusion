# True if any element satisfies the predicate. Input: {"f": predicate, "xs": array}.
# Short-circuits on the first truthy result.
(
  {"f": _ ? @Function, "xs": []} => false,
  {"f": f ? @Function, "xs": [x, ...rest]} => x | f | (
    false => {"f": f, "xs": rest} | @,
    null  => {"f": f, "xs": rest} | @,
    _     => true
  ),
  x => !{"kind": "argument_error", "origin": "stdlib", "operation": "@any", "status": 0, "input": x, "expected": ["{\"f\": _ ? @Function, \"xs\": _ ? @Array}"]}
)
