# Elementwise sum of a non-empty array of equally sized matrices: a reduce
# over @matrix/add.
(
  matrices ? ([first, ...rest] ? (list => {"c": list, "f": @Matrix} | @all) =>
      [first, ...rest] |: @dimensions | @OP.equal) =>
    matrices |+ @add,
  x => !{"kind": "argument_error", "origin": "stdlib", "operation": "@matrix/sum", "status": 0, "input": x, "expected": ["_ ? ([first, ...rest] ? (list => {\"c\": list, \"f\": @matrix/Matrix} | @all) => [first, ...rest] |: @matrix/dimensions | @OP.equal)"]}
)
