  {"f": _ ? @Function, "xs": []} => [],
  {"f": f ? @Function, "xs": [x, ...rest]} => [x | f, ...({"f": f, "xs": rest} | @)],
  {"f": f ? @Function, "xs": obj ? @Object} => {"f": (k => [k, [obj, k] | @get | f]), "xs": obj | @keys} | @ | @toObject,
  x => !{"kind": "argument_error", "origin": "stdlib", "operation": "@map", "status": 0, "input": x, "expected": ["{\"f\": _ ? @Function, \"xs\": _ ? @Array}", "{\"f\": _ ? @Function, \"xs\": _ ? @Object}"]}
)
