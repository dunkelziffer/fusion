#!/usr/bin/env ruby
# frozen_string_literal: true

# Fusion CLI entrypoint.
#
# A file contains exactly one value. A file is "executable" if that value is a
# function; the runtime computes  STDIN | thatFunction  and prints the result.
#
# Usage:
#   echo '[1,2,3]' | fusion path/to/main.fsn
#   fusion path/to/main.fsn '<json-input>'        # input as an argument
#   fusion -e '(n => [n,2] | @multiply)' '21'     # inline program
#
# The CLI contract uses stdout for the result and stderr for the error payload
# only. There is no channel for raw Ruby errors, so every failure is converted to
# a standardized payloaded error (see docs/lang/design.md §2.9) and printed as
# JSON to stderr with exit 1. The lone exception is an internal-invariant assert
# (an "Unreachable" that is not a parse error) — reaching it is an interpreter bug,
# so it is allowed to surface as a Ruby error.

require_relative "../lib/fusion"

def emit(runtime_value)
  status, json = Fusion::CLI.serialize(runtime_value)
  (status.zero? ? $stdout : $stderr).puts json
  exit status
end

begin
  args = ARGV.dup
  inline = nil
  if args[0] == "-e"
    inline = args[1]
    program_path = nil
    explicit_input = args[2]
  else
    program_path = args[0]
    explicit_input = args[1]
  end

  stdlib = File.expand_path("../stdlib", __dir__)
  interp = Fusion::Interpreter.new(stdlib_dir: (Dir.exist?(stdlib) ? stdlib : nil))

  # Determine the program function value.
  program_value =
    if inline
      ast = Fusion::Parser.parse_file(inline, location: "code <inline>")
      if ast.is_a?(Fusion::Interpreter::ErrorVal)
        ast # a parse error becomes the program value and propagates below
      else
        env = interp.root_env.child
        env.define("__dir__", Dir.pwd)
        interp.eval_expr(ast, env)
      end
    else
      abort("usage: fusion <file.fsn> [json-input]   or   fusion -e '<src>' [json-input]") unless program_path
      interp.load_file(File.expand_path(program_path)).force
    end

  # Read input: explicit arg wins, else stdin.
  input_text = explicit_input || ($stdin.tty? ? "" : $stdin.read)
  input_text = "null" if input_text.nil? || input_text.strip.empty?
  input_value = Fusion::CLI.parse(input_text)

  emit(interp.apply(program_value, input_value))
rescue SystemExit
  raise # let exit()/abort() through untouched
rescue Fusion::Unreachable
  raise # internal-invariant assert — a bug; allowed to surface as a Ruby error
rescue Exception => err # rubocop:disable Lint/RescueException
  # Final safety net: SystemStackError and any other escaped Ruby error become a
  # payloaded error rather than a raw backtrace on stderr.
  kind, message = err.is_a?(SystemStackError) ? ["stack_error", "recursion too deep"] : ["type_error", err.message]
  emit(
    Fusion::Interpreter::ErrorVal.internal(
      kind: kind,
      location: "interpreter",
      operation: "running the program",
      input: Fusion::Interpreter::NULL,
      message: message
    )
  )
end
